{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/",                     "destination": "/index" },
    { "source": "/preview",              "destination": "/preview/index" },
    { "source": "/dashboard",            "destination": "/preview/dashboard-overview" },
    { "source": "/dashboard-overview",   "destination": "/preview/dashboard-overview" },
    { "source": "/wallets",              "destination": "/preview/web3-wallets" },
    { "source": "/web3-wallets",         "destination": "/preview/web3-wallets" },
    { "source": "/transactions",         "destination": "/preview/web3-transactions" },
    { "source": "/web3-transactions",    "destination": "/preview/web3-transactions" },
    { "source": "/ai-prompts",           "destination": "/preview/ai-prompts" },
    { "source": "/ai-usage",             "destination": "/preview/ai-usage" },
    { "source": "/settings-profile",     "destination": "/preview/settings-profile" },
    { "source": "/settings-billing",     "destination": "/preview/settings-billing" },
    { "source": "/settings-team",        "destination": "/preview/settings-team" },
    { "source": "/marketing-pricing",    "destination": "/preview/marketing-pricing" },
    { "source": "/components",           "destination": "/preview/components" },
    { "source": "/auth-login",           "destination": "/preview/auth-login" },
    { "source": "/auth-signup",          "destination": "/preview/auth-signup" },
    { "source": "/auth-wallet",          "destination": "/preview/auth-wallet" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
